import json
import boto3
from datetime import datetime

dynamodb = boto3.resource('dynamodb')

employees_table = dynamodb.Table('employees')
assignments_table = dynamodb.Table('assignments')


def lambda_handler(event, context):
    try:
        employees = employees_table.scan().get('Items', [])
        assignments = assignments_table.scan().get('Items', [])

        current_time = datetime.utcnow()

        employee_results = []
        department_stats = {}

        for emp in employees:
            emp_id = emp.get('employee_id')
            name = emp.get('name', 'Unknown')
            department = emp.get('department', 'General')

            emp_assignments = []
            for a in assignments:
                if a.get('employee_id') == emp_id:
                    emp_assignments.append(a)

            total = len(emp_assignments)
            completed = 0
            course_list = []

            for a in emp_assignments:
                status = a.get('status', 'not_started')
                due_date_str = a.get('due_date')

                try:
                    if due_date_str:
                        due_date = datetime.fromisoformat(due_date_str)
                    else:
                        due_date = current_time
                except:
                    due_date = current_time

                if status != 'passed' and due_date < current_time:
                    status = 'overdue'

                if status == 'passed':
                    completed += 1

                course_list.append({
                    'course_id': a.get('course_id'),
                    'status': status
                })

            if total == 0:
                overall_status = 'not_started'
            elif completed == total:
                overall_status = 'passed'
            elif completed > 0:
                overall_status = 'in_progress'
            else:
                overall_status = 'not_started'

            employee_results.append({
                'employee_id': emp_id,
                'name': name,
                'department': department,
                'overall_status': overall_status,
                'courses': course_list
            })

            if department not in department_stats:
                department_stats[department] = {'total': 0, 'completed': 0}

            department_stats[department]['total'] += 1

            if overall_status == 'passed':
                department_stats[department]['completed'] += 1

        skill_matrix = []

        for dept in department_stats:
            total = department_stats[dept]['total']
            completed = department_stats[dept]['completed']

            if total > 0:
                percentage = (completed / total) * 100
            else:
                percentage = 0

            skill_matrix.append({
                'department': dept,
                'completion_percentage': round(percentage, 2)
            })

        return {
            'statusCode': 200,
            'body': json.dumps({
                'employees': employee_results,
                'skill_matrix': skill_matrix
            })
        }

    except Exception as e:
        return {
            'statusCode': 500,
            'body': json.dumps({
                'error': str(e)
            })
        }
